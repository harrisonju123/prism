---
const GITHUB_URL = 'https://github.com/harrisonju123/PrisM';
const RELEASES_URL = 'https://github.com/harrisonju123/PrisM/releases';
const VERSION = 'v0.1.0-alpha.1';
---

<section id="hero" class="min-h-screen flex flex-col items-center justify-center px-6 pt-14 text-center">
  <div class="max-w-[720px] mx-auto">
    <h1 id="hero-h1" class="text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-heading leading-tight tracking-tight mb-6 opacity-0">
      An AI workspace where agents do software and humans supervise.
    </h1>

    <p id="hero-sub" class="text-lg text-body max-w-[560px] mx-auto mb-10 leading-relaxed opacity-0">
      The agent thread is the primary unit of work. Code, debugging, review, and testing are panes inside the workflow. Built on Zed, written in Rust.
    </p>

    <div id="hero-ctas" class="flex flex-wrap items-center justify-center gap-4 mb-8 opacity-0">
      <a
        href={RELEASES_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-bg font-semibold px-6 py-3 rounded-lg transition-colors duration-200 text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download for macOS
      </a>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-border hover:border-accent text-body hover:text-accent font-semibold px-6 py-3 rounded-lg transition-colors duration-200 text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <p id="hero-version" class="text-sm text-muted opacity-0">
      {VERSION} &middot; macOS Apple Silicon, Intel &middot; Linux
    </p>
  </div>
</section>
