From 58c20529ee94de76fab298663527d2ce0f949cb2 Mon Sep 17 00:00:00 2001
From: Harrison Ju <harrisonju@gmail.com>
Date: Sat, 7 Mar 2026 03:47:49 -0500
Subject: [PATCH 6/6] feat(zed): strip Zed telemetry and account UI for PrisM
 fork
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- send_event() no-op: drops all telemetry events without touching call sites
- TelemetrySettingsContent::default() → diagnostics/metrics both false
- default.json: telemetry off, title bar sign-in/user-menu/avatar hidden

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 zed-upstream/assets/settings/default.json            | 12 ++++++------
 .../crates/settings_content/src/settings_content.rs  |  4 ++--
 zed-upstream/crates/telemetry/src/telemetry.rs       |  6 ++----
 3 files changed, 10 insertions(+), 12 deletions(-)

diff --git a/zed-upstream/assets/settings/default.json b/zed-upstream/assets/settings/default.json
index 8231374..00c65a8 100644
--- a/zed-upstream/assets/settings/default.json
+++ b/zed-upstream/assets/settings/default.json
@@ -451,13 +451,13 @@
     // Whether to show the project host and name in the titlebar.
     "show_project_items": true,
     // Whether to show onboarding banners in the titlebar.
-    "show_onboarding_banner": true,
+    "show_onboarding_banner": false,
     // Whether to show user picture in the titlebar.
-    "show_user_picture": true,
+    "show_user_picture": false,
     // Whether to show the user menu in the titlebar.
-    "show_user_menu": true,
+    "show_user_menu": false,
     // Whether to show the sign in button in the titlebar.
-    "show_sign_in": true,
+    "show_sign_in": false,
     // Whether to show the menus in the titlebar.
     "show_menus": false,
   },
@@ -1354,9 +1354,9 @@
   // Control what info is collected by Zed.
   "telemetry": {
     // Send debug info like crash reports.
-    "diagnostics": true,
+    "diagnostics": false,
     // Send anonymized usage data like what languages you're using Zed with.
-    "metrics": true,
+    "metrics": false,
   },
   // Whether to disable all AI features in Zed.
   //
diff --git a/zed-upstream/crates/settings_content/src/settings_content.rs b/zed-upstream/crates/settings_content/src/settings_content.rs
index 5a4e87c..a385a68 100644
--- a/zed-upstream/crates/settings_content/src/settings_content.rs
+++ b/zed-upstream/crates/settings_content/src/settings_content.rs
@@ -456,8 +456,8 @@ pub struct TelemetrySettingsContent {
 impl Default for TelemetrySettingsContent {
     fn default() -> Self {
         Self {
-            diagnostics: Some(true),
-            metrics: Some(true),
+            diagnostics: Some(false),
+            metrics: Some(false),
         }
     }
 }
diff --git a/zed-upstream/crates/telemetry/src/telemetry.rs b/zed-upstream/crates/telemetry/src/telemetry.rs
index e6c8516..41f4f44 100644
--- a/zed-upstream/crates/telemetry/src/telemetry.rs
+++ b/zed-upstream/crates/telemetry/src/telemetry.rs
@@ -53,10 +53,8 @@ macro_rules! serialize_property {
     };
 }
 
-pub fn send_event(event: Event) {
-    if let Some(queue) = TELEMETRY_QUEUE.get() {
-        queue.unbounded_send(event).ok();
-    }
+pub fn send_event(_event: Event) {
+    // Telemetry disabled in PrisM fork.
 }
 
 pub fn init(tx: mpsc::UnboundedSender<Event>) {
-- 
