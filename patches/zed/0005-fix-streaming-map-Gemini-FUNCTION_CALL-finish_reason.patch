From 455aa979dcbee3517dada3130a797b6f27785542 Mon Sep 17 00:00:00 2001
From: Harrison Ju <harrisonju@gmail.com>
Date: Sat, 7 Mar 2026 03:34:17 -0500
Subject: [PATCH 5/6] fix(streaming): map Gemini FUNCTION_CALL finish_reason +
 handle length in Zed

- GeminiStreamConverter: add "FUNCTION_CALL" -> "tool_calls" arm in
  streaming finish_reason match (non-streaming path already had it)
- OpenAiEventMapper: add "length" -> StopReason::MaxTokens arm to
  silence noisy error log when Anthropic stops due to max_tokens

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 zed-upstream/crates/language_models/src/provider/open_ai.rs | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/zed-upstream/crates/language_models/src/provider/open_ai.rs b/zed-upstream/crates/language_models/src/provider/open_ai.rs
index 9f4c6b4..079be9a 100644
--- a/zed-upstream/crates/language_models/src/provider/open_ai.rs
+++ b/zed-upstream/crates/language_models/src/provider/open_ai.rs
@@ -855,6 +855,9 @@ impl OpenAiEventMapper {
             Some("stop") => {
                 events.push(Ok(LanguageModelCompletionEvent::Stop(StopReason::EndTurn)));
             }
+            Some("length") => {
+                events.push(Ok(LanguageModelCompletionEvent::Stop(StopReason::MaxTokens)));
+            }
             Some("tool_calls") => {
                 events.extend(self.tool_calls_by_index.drain().map(|(_, tool_call)| {
                     match parse_tool_arguments(&tool_call.arguments) {
-- 
