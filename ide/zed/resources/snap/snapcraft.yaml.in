name: prism
title: Prism
base: core24
version: "$RELEASE_VERSION"
summary: The editor for what's next
description: |
  Prism is a modern open-source code editor, built from the ground up in Rust with
  a GPU-accelerated renderer. We help you build software faster than ever before.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/harrisonju123/PrisM
source-code: https://github.com/harrisonju123/PrisM
issues: https://github.com/harrisonju123/PrisM/issues
contact: https://github.com/harrisonju123/PrisM

parts:
  prism:
    plugin: dump
    source: "https://github.com/harrisonju123/PrisM/releases/download/v$RELEASE_VERSION/prism-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Prism exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Prism exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  prism:
    command: usr/bin/prism
    common-id: dev.prism.Prism
    environment:
      PRISM_BUNDLE_TYPE: snap
